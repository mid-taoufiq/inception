FROM debian:bullseye

RUN apt-get update && \ 
    apt-get install nginx openssl \
    mkdir -p /etc/nginx/certs \
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout /etc/nginx/certs/nginx.key -out /etc/nginx/certs/nginx.crt -subj "/C=MA/ST=khouribga/L=khouribga/O=42/OU=1337/CN=zguellou.42.fr/UID=zguellou"

COPY tools/nginx.conf /etc/nginx/nginx.conf

RUN chmod +x /usr/local/bin/script.sh

WORKDIR /home/tibarike/Desktop/inception/srcs/requirements/nginx/

EXPOSE 443

ENTRYPOINT [ "nginx", "-g", "daemon off;" ]
