FROM debian:bullseye

RUN apt-get update && \ 
    apt-get install --no-install-recommends -y nginx openssl && \
    mkdir -p /etc/nginx/ssl && \
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout /etc/nginx/ssl/nginx_cert_key.key -out /etc/nginx/ssl/nginx_cert.crt -subj "/C=MA/ST=BeniMellal-Khénifra/L=khouribga/O=42/OU=1337/CN=tibarike.42.fr/UID=tibarike"

COPY tools/nginx.conf /etc/nginx/nginx.conf

EXPOSE 443

ENTRYPOINT [ "nginx", "-g", "daemon off;" ]
